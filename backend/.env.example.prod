# Production example environment variables for backend
# Copy this file to `.env` locally or fill values in your Render/host dashboard.

# MongoDB connection string (MongoDB Atlas recommended)
DATABASE_URL="mongodb+srv://<USER>:<PASS>@cluster0.mongodb.net/ai_job_alerts?retryWrites=true&w=majority"

# Redis connection (if you have a single URL use REDIS_HOST & REDIS_PORT or set REDIS_URL accordingly)
REDIS_HOST="redis-host"
REDIS_PORT=6379
REDIS_PASSWORD=""

# JWT secrets
JWT_ACCESS_SECRET="replace-with-long-random-string"
JWT_REFRESH_SECRET="replace-with-long-random-string"

# Optional token expirations
JWT_ACCESS_TOKEN_EXPIRATION="15m"
JWT_REFRESH_TOKEN_EXPIRATION="7d"

# OpenAI key (optional)
OPENAI_API_KEY=""

# Frontend URL (used for CORS / callbacks)
CLIENT_URL="https://your-frontend-url"

# Cron schedule for scraping (optional)
SCRAPE_CRON_SCHEDULE="0 */6 * * *"

# Port (Render may provide a different port automatically)
PORT=5000
